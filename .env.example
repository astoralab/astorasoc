SECRET_KEY=change-this-to-a-long-random-secret
MYSQL_DATABASE=astorasoc
MYSQL_USER=astorasoc
MYSQL_PASSWORD=change-this-database-password
MYSQL_ROOT_PASSWORD=change-this-root-password
DATABASE_URL=mysql+pymysql://astorasoc:change-this-database-password@db:3306/astorasoc
WEBHOOK_API_KEY=change-this-to-a-long-random-webhook-key
MAX_CONTENT_LENGTH=26214400
SESSION_COOKIE_SECURE=false
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=300 per minute
TRUST_PROXY_HEADERS=true
UPLOAD_FOLDER=/app/app/uploads

# Optional Wazuh active-response API integration.
WAZUH_API_URL=
WAZUH_API_TOKEN=
